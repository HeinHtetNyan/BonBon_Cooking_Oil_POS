# APPLICATION
APP_ENV=production
APP_NAME="Bon Bon Oil ERP"
APP_VERSION=0.1.0
APP_DEBUG=false
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ALLOWED_HOSTS=["your-vps-ip-or-domain"]
ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# DATABASE
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bonbon_oil_db
POSTGRES_USER=bonbon_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_ECHO=false

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CELERY_DB=2

# CELERY
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_ALWAYS_EAGER=false

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=bonbon-oil-erp

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/bonbon_oil/app.log

# PAGINATION
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=500

# MULTI-TENANT (future)
TENANT_ID=default

# CLOUDFLARE R2 (backup uploader)
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_ACCOUNT_ID=CHANGE_ME
R2_BUCKET=bonbon-oil-backups
